{
    "compilerOptions": {
      "experimentalDecorators": true,
      "module": "ESNext",
      "noImplicitAny": true,
      "removeComments": true,
      "resolveJsonModule": true,
      "preserveConstEnums": true,
      "sourceMap": true,
      "moduleResolution": "Bundler",
      "target": "es6",
      "lib": ["ES2020", "DOM", "DOM.Iterable"],
      "types": ["vitest/globals"]
    },
    "include": ["src/**/*", "tests/**/*"],
    "exclude": ["node_modules"]
  }